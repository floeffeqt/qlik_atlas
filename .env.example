# ============================================================
# Qlik Atlas — Environment Template
# Kopiere diese Datei als .env.dev oder .env.prod und fülle
# alle CHANGE_ME-Werte aus.
# Starte mit: docker compose up -d                    (dev)
#             ENV_FILE=.env.prod docker compose up -d (prod)
# ============================================================

# Database
POSTGRES_USER=atlas
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=atlas_db
DATABASE_URL=postgresql+asyncpg://atlas:CHANGE_ME@db:5432/atlas_db

# App
APP_ENV=dev
PORT=8000

# JWT — generieren mit: openssl rand -base64 64
JWT_SECRET=CHANGE_ME
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Qlik API
QLIK_TENANT_URL=
QLIK_API_KEY=

# ===========================================================
# !! KRITISCH — CREDENTIALS_AES256_GCM_KEY_B64 !!
#
# Dieser Key verschlüsselt ALLE Kunden-Credentials in der DB.
# In Produktion darf sich dieser Wert NIEMALS ändern, sobald
# Daten existieren — sonst sind alle Credentials unleserlich.
# Separates Backup im Passwort-Manager pflegen!
#
# Generieren mit:
#   python -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# ===========================================================
CREDENTIALS_AES256_GCM_KEY_B64=CHANGE_ME
CREDENTIALS_AES256_GCM_KEY_ID=local-dev-v1

# Admin User (wird beim ersten Start automatisch angelegt)
ADMIN_EMAIL=CHANGE_ME_admin@your-domain.com
ADMIN_PASSWORD=CHANGE_ME

# Frontend

# pgAdmin (nur mit --profile dev)
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=pgadmin@local.dev
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME
